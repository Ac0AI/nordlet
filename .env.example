# =========================================
# NordLet / Frihetstoa — miljövariabler
# Kopiera till .env.local och fyll i värdena
# =========================================

# Google Gemini API (används av scripts/generate-operativprincip.mjs).
# Synkas från hubens Projekt/.env.shared via `pnpm sync-env`.
GEMINI_API_KEY=

# ---- STRIPE PAYMENT LINKS ----
# Skapa Payment Links i Stripe Dashboard (Betalning → Payment links).
# För varje paket: välj/skapa Produkt, sätt Pris, välj "Collect shipping address"
# (begränsa till Sverige), aktivera bekräftelse-email, sätt "After payment →
# Redirect to your website" → https://nordlet.vercel.app/tack
NEXT_PUBLIC_CHECKOUT_URL_FRIHETSTOA=
NEXT_PUBLIC_CHECKOUT_URL_SASONGSPAKET=

# ---- KONTAKT ----
# Lämna tomt om du inte vill publicera nummer än — telefon-CTA:er göms då.
NEXT_PUBLIC_PHONE=

# ---- FÖRETAGSUPPGIFTER (visas i footer + juridiska sidor) ----
# Lagkrav för svensk e-com: org.nr + fullständig adress måste vara synliga.
NEXT_PUBLIC_COMPANY_NAME=NordLet
NEXT_PUBLIC_ORG_NR=
NEXT_PUBLIC_COMPANY_ADDRESS=
